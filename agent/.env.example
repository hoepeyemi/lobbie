# mogause Agent Environment Configuration
# Copy this file to .env and fill in the values

# ═══════════════════════════════════════════════════════════════════════════
# 0G GALILEO NETWORK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Your private key
# Generate one using: npx tsx src/generate-wallet.ts
AGENT_PRIVATE_KEY=S...

# Network selection for 0G Galileo
NETWORK=0G-Galileo-Testnet
CHAIN_ID=16602
TOKEN_SYMBOL=0G
BLOCK_EXPLORER=https://chainscan-galileo.0g.ai

# The URL of the mogause Backend / Facilitator
AGENT_SERVER_URL=http://localhost:3001


# ═══════════════════════════════════════════════════════════════════════════
# AI / LLM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Groq API Key for fast Llama-3 planning
GROQ_API_KEY=gsk_...

# Google Gemini API Key for high-reasoning fallback
GEMINI_API_KEY=AIza...
