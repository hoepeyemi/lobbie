# mogause Agent Environment Configuration
# Copy this file to .env and fill in the values

# ═══════════════════════════════════════════════════════════════════════════
# 0G GALILEO NETWORK CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# EVM private key: 64 hex characters, optional 0x (same as Hardhat / MetaMask export)
# Generate: npm run generate-wallet
AGENT_PRIVATE_KEY=0x...

# Network label for CLI (e.g. testnet on 0G Galileo)
NETWORK=testnet
CHAIN_ID=16602
TOKEN_SYMBOL=0G
BLOCK_EXPLORER=https://chainscan-galileo.0g.ai

# Same as backend CONTRACT_ADDRESS (AgentRegistry on 0G-Galileo-Testnet)
# CONTRACT_ADDRESS=0xe27bCA717aA803dBc1AB3989a915507ddfbbFb4D

# The URL of the mogause Backend / Facilitator
AGENT_SERVER_URL=http://localhost:3001


# ═══════════════════════════════════════════════════════════════════════════
# AI / LLM CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# Groq API Key for fast Llama-3 planning
GROQ_API_KEY=gsk_...

# Google Gemini API Key for high-reasoning fallback
GEMINI_API_KEY=AIza...
