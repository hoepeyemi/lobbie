# Root deployment env for frontend app (if you deploy frontend separately).
# Server path example: /home/ubuntu/mogause/.env.frontend

NEXT_PUBLIC_API_URL=http://localhost:4002
# RainbowKit + WalletConnect (https://cloud.walletconnect.com) — required for WalletConnect QR; browser wallets can work without
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_EVM_RPC_URL=https://evmrpc-testnet.0g.ai
# AgentRegistry (Solidity) on 0G-Galileo-Testnet — used for UI fallbacks; API also returns these
NEXT_PUBLIC_CHAIN_ID=16602
NEXT_PUBLIC_NETWORK_NAME=0G-Galileo-Testnet
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=0xe27bCA717aA803dBc1AB3989a915507ddfbbFb4D
NEXT_PUBLIC_BLOCK_EXPLORER=https://chainscan-galileo.0g.ai
# EVM 0x address to show "Server" balance in navbar; optional
NEXT_PUBLIC_SERVER_ADDRESS=0x...
NEXT_PUBLIC_AGENT_PRIVATE_KEY=
NEXT_PUBLIC_FEATURE_A2A=true
NEXT_PUBLIC_FEATURE_PROTOCOL_TRACE=true
NEXT_PUBLIC_FEATURE_STRESS_TEST=true
NEXT_PUBLIC_ENABLE_WALLET_CONNECT=true
NEXT_PUBLIC_ENABLE_HARDWARE_WALLETS=true
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_REACT_STRICT_MODE=false
NEXT_PUBLIC_SESSION_TIMEOUT=30
